# AI Service Configuration
# glm-4.7-flash
GLM_API_KEY=your_glm_api_key_here
# glm-4v-flash (视觉模型)
GLM_4V_API_KEY=your_glm_4v_api_key_here

GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# 模型名称配置（可通过环境变量覆盖）
# AI_PRIMARY_MODEL=glm-4.5-air
# AI_FALLBACK_MODEL=glm-4-flash
# AI_VISION_MODEL=glm-4v-flash
# AI_SUPPLEMENT_MODEL=glm-4.5-air
# AI_REPORT_MODEL=glm-4.5-air
AI_MAX_TOKENS=512

# gRPC 加密传输（生产环境务必开启）
# GRPC_SECURE=true
# GRPC_SERVER_CERT=./certs/server.crt
# GRPC_SERVER_KEY=./certs/server.key
